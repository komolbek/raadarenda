FROM node:20-alpine AS deps
RUN corepack enable && corepack prepare pnpm@10.16.1 --activate
WORKDIR /app
COPY package.json pnpm-workspace.yaml turbo.json ./
COPY apps/web/package.json ./apps/web/
COPY packages/types/package.json ./packages/types/
COPY packages/validators/package.json ./packages/validators/
RUN pnpm install --no-frozen-lockfile --ignore-scripts

FROM node:20-alpine AS builder
RUN corepack enable && corepack prepare pnpm@10.16.1 --activate
WORKDIR /app
COPY --from=deps /app ./
COPY apps/web/ ./apps/web/
COPY packages/types/ ./packages/types/
COPY packages/validators/ ./packages/validators/
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_TELEMETRY_DISABLED=1
RUN cd apps/web && npx next build

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
RUN addgroup --system --gid 1001 nodejs && adduser --system --uid 1001 nextjs
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
# Ship the public/ folder — logo SVGs, payment provider logos, etc.
# Next.js standalone serves static assets relative to the server.js cwd.
# Railway's startCommand in apps/web/railway.json is `node server.js`,
# so the process CWD ends up at /app/apps/web; without a public/ dir
# beside server.js every /logo/*, /images/* request 404s.
# Also mirror public/ at the repo root in case the CMD path is used.
COPY --from=builder /app/apps/web/public ./apps/web/public
COPY --from=builder /app/apps/web/public ./public
RUN chown -R nextjs:nodejs /app
USER nextjs
EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"
CMD ["node", "apps/web/server.js"]
