# Database
DATABASE_URL="postgresql://user:password@localhost:5432/4event?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Admin
ADMIN_API_KEY="your-secure-admin-api-key"
ADMIN_SESSION_SECRET="your-session-signing-secret"

# SMS Service ("mock" for development, "gateway" for production via sms-gateway, "eskiz" for direct)
SMS_PROVIDER="mock"
SMS_API_KEY=""
SMS_SENDER=""
ESKIZ_API_TOKEN=""

# SMS Gateway (required when SMS_PROVIDER="gateway")
SMS_GATEWAY_URL="http://localhost:3010/api/v1"
SMS_GATEWAY_API_KEY=""

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Yandex Maps
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=""

# Test Auth (NEVER enable in production)
# ENABLE_TEST_AUTH="true"
# TEST_PHONE_NUMBERS="998111111111,998000000000"
# TEST_OTP_CODE="123456"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# CORS — comma-separated list of allowed origins for cross-origin API requests
# NEXT_PUBLIC_APP_URL is always allowed automatically
ALLOWED_ORIGINS=""
