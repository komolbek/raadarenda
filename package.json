{
  "name": "4event",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "dev:api": "turbo dev --filter=@4event/api",
    "dev:web": "turbo dev --filter=@4event/web",
    "dev:admin": "turbo dev --filter=@4event/admin",
    "build:api": "turbo build --filter=@4event/api",
    "build:web": "turbo build --filter=@4event/web",
    "build:admin": "turbo build --filter=@4event/admin",
    "db:generate": "turbo db:generate --filter=@4event/db",
    "db:push": "turbo db:push --filter=@4event/db",
    "db:studio": "pnpm --filter @4event/db db:studio"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@10.16.1",
  "engines": {
    "node": ">=20.0.0"
  }
}
